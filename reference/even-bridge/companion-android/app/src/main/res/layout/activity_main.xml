<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/root_scroll"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/app_bg"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="@dimen/et_spacing_card">

        <!-- ── Header ──────────────────────────────────────────────────────── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginTop="@dimen/et_spacing_margin"
            android:layout_marginBottom="@dimen/et_spacing_card">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="homeauto.cc"
                    android:textColor="@color/app_text"
                    style="@style/EvenText.LargeTitle"
                    android:fontFamily="sans-serif-light" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="APPS Bridge"
                    style="@style/EvenText.Subtitle" />
            </LinearLayout>

            <TextView
                android:id="@+id/tv_version"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                style="@style/EvenText.Detail" />
        </LinearLayout>

        <!-- Phone style, matched to MotoHUD2 -->
        <LinearLayout
            android:id="@+id/card_theme"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/card_bg"
            android:padding="@dimen/et_spacing_card"
            android:layout_marginBottom="@dimen/et_spacing_card">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="PHONE STYLE"
                android:textColor="@color/app_text_muted"
                style="@style/EvenText.Detail"
                android:textAllCaps="true"
                android:layout_marginBottom="@dimen/et_spacing_same" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Auto follows your phone. Light and Dark override it for this app."
                style="@style/EvenText.Detail"
                android:layout_marginBottom="@dimen/et_spacing_cross" />

            <LinearLayout
                android:id="@+id/theme_group"
                android:layout_width="match_parent"
                android:layout_height="@dimen/et_button_sm_height"
                android:orientation="horizontal"
                android:background="@drawable/even_segmented_group_bg"
                android:padding="2dp">

                <Button
                    android:id="@+id/btn_theme_auto"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:text="Auto"
                    android:minHeight="0dp"
                    android:minWidth="0dp"
                    android:textAllCaps="false"
                    style="@style/EvenText.Subtitle"
                    android:paddingStart="@dimen/et_spacing_cross"
                    android:paddingEnd="@dimen/et_spacing_cross"
                    android:background="@drawable/even_segmented_item_bg" />

                <Button
                    android:id="@+id/btn_theme_light"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:text="Light"
                    android:minHeight="0dp"
                    android:minWidth="0dp"
                    android:textAllCaps="false"
                    style="@style/EvenText.Subtitle"
                    android:paddingStart="@dimen/et_spacing_cross"
                    android:paddingEnd="@dimen/et_spacing_cross"
                    android:background="@drawable/even_segmented_item_bg" />

                <Button
                    android:id="@+id/btn_theme_dark"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:text="Dark"
                    android:minHeight="0dp"
                    android:minWidth="0dp"
                    android:textAllCaps="false"
                    style="@style/EvenText.Subtitle"
                    android:paddingStart="@dimen/et_spacing_cross"
                    android:paddingEnd="@dimen/et_spacing_cross"
                    android:background="@drawable/even_segmented_item_bg" />
            </LinearLayout>
        </LinearLayout>

        <!-- ── Status card ─────────────────────────────────────────────────── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/card_bg"
            android:padding="@dimen/et_spacing_card"
            android:layout_marginBottom="@dimen/et_spacing_card">

            <!-- Status row: dot + label + button -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="@dimen/et_spacing_cross">

                <View
                    android:id="@+id/dot_status"
                    android:layout_width="8dp"
                    android:layout_height="8dp"
                    android:background="@drawable/status_dot"
                    android:layout_marginEnd="@dimen/et_spacing_cross" />

                <TextView
                    android:id="@+id/tv_status"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Stopped"
                    style="@style/EvenText.NormalTitle" />

                <Button
                    android:id="@+id/btn_bridge"
                    android:layout_width="wrap_content"
                    android:layout_height="@dimen/et_button_sm_height"
                    android:text="Start"
                    android:minHeight="0dp"
                    android:minWidth="0dp"
                    android:background="@drawable/even_button_highlight_bg"
                    android:textColor="@color/app_accent_text"
                    android:textSize="15sp"
                    android:paddingStart="@dimen/et_button_padding_x"
                    android:paddingEnd="@dimen/et_button_padding_x" />
            </LinearLayout>

            <TextView
                android:id="@+id/tv_status_hint"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Tap Start to begin. The bridge wakes GPS only when a HUD connects, saving battery while idle."
                style="@style/EvenText.Detail"
                android:lineSpacingMultiplier="1.45" />
        </LinearLayout>

        <!-- ── Setup card ──────────────────────────────────────────────────── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/card_bg"
            android:padding="@dimen/et_spacing_card"
            android:layout_marginBottom="@dimen/et_spacing_card">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="SETUP"
                style="@style/EvenText.Detail"
                android:textAllCaps="true"
                android:layout_marginBottom="@dimen/et_spacing_same" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Complete these steps once before your first ride."
                style="@style/EvenText.Detail"
                android:layout_marginBottom="@dimen/et_spacing_card" />

            <!-- Notification Access -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="@drawable/even_tile_bg"
                android:padding="@dimen/et_spacing_cross"
                android:layout_marginBottom="@dimen/et_spacing_same">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:paddingEnd="@dimen/et_spacing_cross">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Notification Access"
                        style="@style/EvenText.NormalTitle"
                        android:layout_marginBottom="2dp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Reads media (song, artist, play state), navigation from Maps/Waze/OsmAnd, and message notifications from SMS, WhatsApp, Signal, Telegram, Gmail, and Messenger."
                        style="@style/EvenText.Detail"
                        android:lineSpacingMultiplier="1.35" />
                </LinearLayout>

                <Button
                    android:id="@+id/btn_notif"
                    android:layout_width="wrap_content"
                    android:layout_height="@dimen/et_button_sm_height"
                    android:text="Grant"
                    android:minHeight="0dp"
                    android:minWidth="0dp"
                    android:background="@drawable/even_button_secondary_bg"
                    android:textColor="@color/app_text_dim"
                    android:textSize="12sp"
                    android:paddingStart="@dimen/et_spacing_cross"
                    android:paddingEnd="@dimen/et_spacing_cross" />
            </LinearLayout>

            <!-- Divider -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="@color/app_border"
                android:layout_marginBottom="@dimen/et_spacing_same" />

            <!-- Battery Optimization -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="@drawable/even_tile_bg"
                android:padding="@dimen/et_spacing_cross">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:paddingEnd="@dimen/et_spacing_cross">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Unrestricted Battery"
                        style="@style/EvenText.NormalTitle"
                        android:layout_marginBottom="2dp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Prevents Android from suspending the bridge mid-ride. Without this, the service may be killed after a few minutes in the background."
                        style="@style/EvenText.Detail"
                        android:lineSpacingMultiplier="1.35" />
                </LinearLayout>

                <Button
                    android:id="@+id/btn_battery"
                    android:layout_width="wrap_content"
                    android:layout_height="@dimen/et_button_sm_height"
                    android:text="Enable"
                    android:minHeight="0dp"
                    android:minWidth="0dp"
                    android:background="@drawable/even_button_secondary_bg"
                    android:textColor="@color/app_text_dim"
                    android:textSize="12sp"
                    android:paddingStart="@dimen/et_spacing_cross"
                    android:paddingEnd="@dimen/et_spacing_cross" />
            </LinearLayout>
        </LinearLayout>

        <!-- ── Notifications card ────────────────────────────────────────────── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/card_bg"
            android:padding="@dimen/et_spacing_card"
            android:layout_marginBottom="@dimen/et_spacing_card">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="NOTIFICATIONS"
                style="@style/EvenText.Detail"
                android:textAllCaps="true"
                android:layout_marginBottom="@dimen/et_spacing_same" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Relay incoming messages to your G2 glasses and reply by voice."
                style="@style/EvenText.Detail"
                android:layout_marginBottom="@dimen/et_spacing_card" />

            <!-- Deepgram key tile -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/even_tile_bg"
                android:padding="@dimen/et_spacing_cross"
                android:layout_marginBottom="@dimen/et_spacing_same">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Deepgram API Key"
                    style="@style/EvenText.NormalTitle"
                    android:layout_marginBottom="2dp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Required for voice-to-text replies. Free tier at deepgram.com/console."
                    style="@style/EvenText.Detail"
                    android:lineSpacingMultiplier="1.35"
                    android:layout_marginBottom="@dimen/et_spacing_cross" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="@dimen/et_spacing_same">

                    <EditText
                        android:id="@+id/et_deepgram_key"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:hint="Paste key here…"
                        android:inputType="textVisiblePassword"
                        android:fontFamily="monospace"
                        android:textSize="12sp"
                        android:textColor="@color/app_text"
                        android:textColorHint="@color/app_text_muted"
                        android:background="@drawable/even_input_bg"
                        android:padding="@dimen/et_spacing_cross"
                        android:layout_marginEnd="@dimen/et_spacing_cross"
                        android:singleLine="true"
                        android:imeOptions="actionDone" />

                    <Button
                        android:id="@+id/btn_save_deepgram"
                        android:layout_width="wrap_content"
                        android:layout_height="@dimen/et_button_sm_height"
                        android:text="Save"
                        android:minHeight="0dp"
                        android:minWidth="0dp"
                        android:textSize="12sp"
                        android:paddingStart="@dimen/et_spacing_cross"
                        android:paddingEnd="@dimen/et_spacing_cross" />
                </LinearLayout>

                <TextView
                    android:id="@+id/tv_deepgram_status"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="No key set — voice replies disabled"
                    style="@style/EvenText.Detail" />
            </LinearLayout>

            <!-- G2 connection status tile -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="@drawable/even_tile_bg"
                android:padding="@dimen/et_spacing_cross"
                android:layout_marginBottom="@dimen/et_spacing_same">

                <View
                    android:id="@+id/dot_notif_ws"
                    android:layout_width="8dp"
                    android:layout_height="8dp"
                    android:background="@drawable/status_dot"
                    android:layout_marginEnd="@dimen/et_spacing_cross" />

                <TextView
                    android:id="@+id/tv_notif_ws"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Waiting for G2 glasses…"
                    style="@style/EvenText.Detail" />
            </LinearLayout>

            <!-- Test reply-to number — lets the test notification exercise the
                 real reply-send path end to end instead of a blank recipient -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/even_tile_bg"
                android:padding="@dimen/et_spacing_cross"
                android:layout_marginBottom="@dimen/et_spacing_same">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Test Reply-To Number"
                    style="@style/EvenText.NormalTitle"
                    android:layout_marginBottom="2dp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Send Test Notification uses this number so the glasses reply reaches a real SMS thread you can check."
                    style="@style/EvenText.Detail"
                    android:lineSpacingMultiplier="1.35"
                    android:layout_marginBottom="@dimen/et_spacing_cross" />

                <EditText
                    android:id="@+id/et_test_phone"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Your own number, e.g. +15551234567"
                    android:inputType="phone"
                    android:fontFamily="monospace"
                    android:textSize="12sp"
                    android:textColor="@color/app_text"
                    android:textColorHint="@color/app_text_muted"
                    android:background="@drawable/even_input_bg"
                    android:padding="@dimen/et_spacing_cross"
                    android:singleLine="true"
                    android:imeOptions="actionDone" />
            </LinearLayout>

            <!-- Test notification -->
            <Button
                android:id="@+id/btn_test_notif"
                android:layout_width="match_parent"
                android:layout_height="@dimen/et_button_sm_height"
                android:text="Send Test Notification"
                android:minHeight="0dp"
                android:textAllCaps="false"
                android:textSize="14sp"
                android:layout_marginBottom="@dimen/et_spacing_same" />

            <!-- Android message source note -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Android relays messages from SMS, WhatsApp, Signal, Telegram, Gmail, and Messenger automatically — no extra setup needed once Notification Access is granted in the Setup section above."
                style="@style/EvenText.Detail"
                android:lineSpacingMultiplier="1.35" />
        </LinearLayout>

        <!-- ── Modules card (expandable, open by default) ───────────────────── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/card_bg"
            android:layout_marginBottom="@dimen/et_spacing_card">

            <LinearLayout
                android:id="@+id/header_modules"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:padding="@dimen/et_spacing_card"
                android:clickable="true"
                android:focusable="true"
                android:background="?attr/selectableItemBackground">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="MODULES"
                    style="@style/EvenText.Detail"
                    android:textAllCaps="true" />

                <TextView
                    android:id="@+id/arrow_modules"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="▾"
                    android:textColor="@color/app_text_dim"
                    android:textSize="14sp" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/content_modules"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingStart="@dimen/et_spacing_card"
                android:paddingEnd="@dimen/et_spacing_card"
                android:paddingBottom="@dimen/et_spacing_card">

                <!-- Moto HUD module -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:background="@drawable/even_tile_bg"
                    android:padding="@dimen/et_spacing_cross"
                    android:layout_marginBottom="@dimen/et_spacing_same">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="@dimen/et_spacing_same">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Moto HUD"
                            style="@style/EvenText.NormalTitle" />

                        <View
                            android:id="@+id/dot_hud"
                            android:layout_width="8dp"
                            android:layout_height="8dp"
                            android:background="@drawable/status_dot" />
                    </LinearLayout>

                    <TextView
                        android:id="@+id/tv_module_hud"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="WS :7071    no clients\nHTTP :7070  standby\nGPS         off"
                        android:textColor="@color/app_text_dim"
                        android:textSize="12sp"
                        android:fontFamily="monospace"
                        android:lineSpacingMultiplier="1.6" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Provides GPS location, speed, media playback, and navigation data to the Moto HUD glasses app over WebSocket and HTTP."
                        style="@style/EvenText.Detail"
                        android:lineSpacingMultiplier="1.4"
                        android:layout_marginTop="@dimen/et_spacing_same" />
                </LinearLayout>

                <!-- CC Live module -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:background="@drawable/even_tile_bg"
                    android:padding="@dimen/et_spacing_cross"
                    android:layout_marginBottom="@dimen/et_spacing_same">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="@dimen/et_spacing_same">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="CC Live"
                            style="@style/EvenText.NormalTitle" />

                        <View
                            android:id="@+id/dot_cc_live"
                            android:layout_width="8dp"
                            android:layout_height="8dp"
                            android:background="@drawable/status_dot" />
                    </LinearLayout>

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Provides Android Phone Audio capture for CC Live when requested from the glasses. Some apps may block capture. Phone calls are not supported."
                        style="@style/EvenText.Detail"
                        android:lineSpacingMultiplier="1.4"
                        android:layout_marginBottom="@dimen/et_spacing_cross" />

                    <TextView
                        android:id="@+id/tv_cc_status"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="source   android_media\ncapture  idle\nengine   stub"
                        android:textColor="@color/app_text_dim"
                        android:textSize="12sp"
                        android:fontFamily="monospace"
                        android:lineSpacingMultiplier="1.6"
                        android:background="@drawable/even_input_bg"
                        android:padding="@dimen/et_spacing_cross" />
                </LinearLayout>

                <!-- Bluetooth GATT placeholder -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:background="@drawable/even_tile_bg"
                    android:padding="@dimen/et_spacing_cross">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="@dimen/et_spacing_same">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Bluetooth GATT"
                            style="@style/EvenText.NormalTitle" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="COMING SOON"
                            android:textColor="@color/app_text_dim"
                            android:textSize="11sp"
                            android:background="@drawable/even_badge_neutral_bg"
                            android:textAllCaps="true" />
                    </LinearLayout>

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Reserved for a future homeauto.cc app. Will connect to a Bluetooth Low Energy GATT device and relay its data to glasses apps."
                        style="@style/EvenText.Detail"
                        android:lineSpacingMultiplier="1.4" />
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>

        <!-- ── Live Data card (expandable, collapsed by default) ─────────────── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/card_bg"
            android:layout_marginBottom="@dimen/et_spacing_card">

            <LinearLayout
                android:id="@+id/header_data"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:padding="@dimen/et_spacing_card"
                android:clickable="true"
                android:focusable="true"
                android:background="?attr/selectableItemBackground">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="LIVE DATA"
                    style="@style/EvenText.Detail"
                    android:textAllCaps="true" />

                <TextView
                    android:id="@+id/arrow_data"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="▸"
                    android:textColor="@color/app_text_dim"
                    android:textSize="14sp" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/content_data"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone"
                android:paddingStart="@dimen/et_spacing_card"
                android:paddingEnd="@dimen/et_spacing_card"
                android:paddingBottom="@dimen/et_spacing_card">

                <TextView
                    android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Live sensor values as received — useful for diagnosing GPS or media issues."
                style="@style/EvenText.Detail"
                android:lineSpacingMultiplier="1.4"
                android:layout_marginBottom="@dimen/et_spacing_cross" />

                <!-- GPS panel -->
                <TextView
                    android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="GPS"
                style="@style/EvenText.Detail"
                android:textAllCaps="true"
                android:layout_marginBottom="@dimen/et_spacing_same" />

                <TextView
                    android:id="@+id/tv_gps"
                    android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="--"
                android:textColor="@color/app_text_dim"
                android:textSize="12sp"
                android:fontFamily="monospace"
                android:lineSpacingMultiplier="1.6"
                android:background="@drawable/even_input_bg"
                android:padding="@dimen/et_spacing_cross"
                android:layout_marginBottom="@dimen/et_spacing_card" />

                <!-- Media panel -->
                <TextView
                    android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Media"
                style="@style/EvenText.Detail"
                android:textAllCaps="true"
                android:layout_marginBottom="@dimen/et_spacing_same" />

                <TextView
                    android:id="@+id/tv_media"
                    android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="--"
                android:textColor="@color/app_text_dim"
                android:textSize="12sp"
                android:fontFamily="monospace"
                android:lineSpacingMultiplier="1.6"
                android:background="@drawable/even_input_bg"
                android:padding="@dimen/et_spacing_cross"
                android:layout_marginBottom="@dimen/et_spacing_card" />

                <!-- Navigation panel -->
                <TextView
                    android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Navigation"
                style="@style/EvenText.Detail"
                android:textAllCaps="true"
                android:layout_marginBottom="@dimen/et_spacing_same" />

                <TextView
                    android:id="@+id/tv_nav"
                    android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="--"
                android:textColor="@color/app_text_dim"
                android:textSize="12sp"
                android:fontFamily="monospace"
                android:lineSpacingMultiplier="1.6"
                android:background="@drawable/even_input_bg"
                android:padding="@dimen/et_spacing_cross" />
            </LinearLayout>
        </LinearLayout>

        <!-- ── Footer ──────────────────────────────────────────────────────── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:paddingTop="@dimen/et_spacing_same"
            android:paddingBottom="@dimen/et_spacing_section">

            <TextView
                android:id="@+id/tv_about"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                style="@style/EvenText.Detail"
                android:gravity="center"
                android:lineSpacingMultiplier="1.5" />
        </LinearLayout>

    </LinearLayout>
</ScrollView>
